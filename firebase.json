{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "/*/preview",  "destination": "/tool.html" },
      { "source": "/*/download", "destination": "/tool.html" },
      { "source": "**",          "destination": "/tool.html" }
    ]
  }
}
