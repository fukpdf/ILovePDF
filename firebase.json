{
  "hosting": {
    "public": "public",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/ads.txt",
        "destination": "/ads.txt"
      },
      {
        "source": "/!(ads.txt)**",
        "destination": "/tool.html"
      }
    ]
  }
}
