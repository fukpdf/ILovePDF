# ───────────────────────────────────────────────────────────────────────
# ILovePDF — Environment configuration
# Copy this file to .env (or set in Replit Secrets) and fill in real values.
# NEVER commit .env to git.
# ───────────────────────────────────────────────────────────────────────

# Server
PORT=5000
JWT_SECRET=change-me-to-a-long-random-string
ALLOWED_ORIGINS=https://www.yourdomain.com,https://app.yourdomain.com
MAX_UPLOAD_MB=100

# ── Firebase (web SDK config — exposed to browser by /api/config/firebase) ──
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project
FIREBASE_APP_ID=1:1234567890:web:abcdef

# ── Firebase Admin (backend ID-token verification) ────────────────────
# Paste the ENTIRE service-account JSON file as a single line.
# Console -> Project Settings -> Service Accounts -> Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...", "...":"..."}

# ── Cloudflare R2 (S3-compatible object storage) ──────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ilovepdf-storage

# ── Hugging Face (AI tools only: summarize, translate, bg-remove) ─────
HUGGINGFACE_API_TOKEN=
