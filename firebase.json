{
  "hosting": {
    "public": "public",
    "cleanUrls": true,
    "headers": [
      {
        "source": "/ads.txt",
        "headers": [
          {
            "key": "Content-Type",
            "value": "text/plain"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/ads.txt",
        "destination": "/ads.txt"
      },
      {
        "source": "**",
        "destination": "/tool.html"
      }
    ]
  }
}
